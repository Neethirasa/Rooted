# Apple iCloud Custom Domain SMTP Configuration for Contact Form
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_SECURE=false # Must be false when using 587. Nodemailer will automatically upgrade to TLS with STARTTLS.
SMTP_USER=nivethikan7@icloud.com # Use the main Apple ID email that owns the custom domain
SMTP_PASS=xxxx-xxxx-xxxx-xxxx # This MUST be an App-Specific Password (not your main Apple ID password)
SMTP_FROM_EMAIL=support@rootedcanada.com # Your custom domain email
